---
import Layout from "../../layouts/Layout.astro";
import LanguagePicker from "../../components/LanguagePicker.astro";
import { useTranslations } from "../../i18n/ui";

// Import both JSONs
import cvEnData from "../../data/cv-en.json";
import cvEsData from "../../data/cv-es.json";

export function getStaticPaths() {
    return [{ params: { lang: "en" } }, { params: { lang: "es" } }];
}

const { lang } = Astro.params as { lang: "en" | "es" };
const t = useTranslations(lang);

// Select correct data based on the dynamic lang route
const cvData = lang === "es" ? cvEsData : cvEnData;

// Compute dynamic labels mapping depending on the language so we don't hardcode them
const cvLanguagesLabels = {
    es: lang === "es" ? "Español" : "Spanish",
    en: lang === "es" ? "Inglés" : "English",
};
---

<Layout title={`CV - ${cvData.personal.name}`}>
    <div
        class="min-h-screen bg-slate-50 py-12 px-4 sm:px-6 lg:px-8 print:bg-white print:py-0"
    >
        <div class="absolute top-6 right-6 z-10 print:hidden">
            <LanguagePicker />
        </div>

        <!-- Main CV Container -->
        <main
            class="max-w-4xl mx-auto bg-white shadow-xl shadow-slate-200/40 rounded-2xl overflow-hidden print:shadow-none print:rounded-none"
        >
            <!-- Header / Hero Section -->
            <header
                class="bg-indigo-900 px-8 py-12 text-white print:bg-transparent print:text-black print:p-0 print:border-b-2 print:border-slate-800"
            >
                <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4">
                    {cvData.personal.name}
                </h1>
                <div
                    class="flex flex-wrap gap-4 text-indigo-200 text-sm md:text-base print:text-slate-600"
                >
                    <span class="flex items-center gap-1">
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                            ></path><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                            ></path></svg
                        >
                        {cvData.personal.location}
                    </span>
                    <a
                        href={`mailto:${cvData.personal.email}`}
                        class="flex items-center gap-1 hover:text-white transition-colors print:text-blue-800"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                            ></path></svg
                        >
                        {cvData.personal.email}
                    </a>
                    <a
                        href={`tel:${cvData.personal.phone.replace(/[^0-9+]/g, "")}`}
                        class="flex items-center gap-1 hover:text-white transition-colors print:text-blue-800"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                            xmlns="http://www.w3.org/2000/svg"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                            ></path></svg
                        >
                        {cvData.personal.phone}
                    </a>
                    <a
                        href={`https://${cvData.personal.linkedin}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center gap-1 hover:text-white transition-colors print:text-blue-800"
                    >
                        <svg
                            class="w-4 h-4"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            aria-hidden="true"
                            ><path
                                fill-rule="evenodd"
                                d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                                clip-rule="evenodd"></path></svg
                        >
                        {cvData.personal.linkedin}
                    </a>
                </div>
            </header>

            <div class="p-8 space-y-10 print:p-0 print:pt-6 print:space-y-6">
                <!-- Professional Summary -->
                <section aria-labelledby="summary-heading">
                    <h2
                        id="summary-heading"
                        class="text-2xl font-bold text-slate-900 border-b-2 border-slate-100 pb-2 mb-4 print:text-xl print:border-slate-800/10 inline-block"
                    >
                        {t("cv.summary")}
                    </h2>
                    <p
                        class="text-slate-600 leading-relaxed print:text-slate-800"
                    >
                        {cvData.summary}
                    </p>
                </section>

                <!-- Technical Skills -->
                <section aria-labelledby="skills-heading">
                    <h2
                        id="skills-heading"
                        class="text-2xl font-bold text-slate-900 border-b-2 border-slate-100 pb-2 mb-4 print:text-xl print:border-slate-800/10 inline-block"
                    >
                        {t("cv.skills")}
                    </h2>
                    <ul
                        class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-3 text-sm text-slate-600 print:text-slate-800 print:block print:space-y-2"
                    >
                        <li>
                            <strong
                                class="text-slate-900 font-semibold print:text-black"
                                >{
                                    lang === "es"
                                        ? "Computación en la Nube:"
                                        : "Cloud Computing:"
                                }</strong
                            >
                            {cvData.skills.cloud}
                        </li>
                        <li>
                            <strong
                                class="text-slate-900 font-semibold print:text-black"
                                >{
                                    lang === "es" ? "Lenguajes:" : "Languages:"
                                }</strong
                            >
                            {cvData.skills.languages}
                        </li>
                        <li>
                            <strong
                                class="text-slate-900 font-semibold print:text-black"
                                >Frameworks:</strong
                            >
                            {cvData.skills.frameworks}
                        </li>
                        <li>
                            <strong
                                class="text-slate-900 font-semibold print:text-black"
                                >{
                                    lang === "es"
                                        ? "Arquitecturas:"
                                        : "Architectures:"
                                }</strong
                            >
                            {cvData.skills.architectures}
                        </li>
                        <li>
                            <strong
                                class="text-slate-900 font-semibold print:text-black"
                                >{
                                    lang === "es"
                                        ? "Bases de Datos:"
                                        : "Databases:"
                                }</strong
                            >
                            {cvData.skills.databases}
                        </li>
                        <li>
                            <strong
                                class="text-slate-900 font-semibold print:text-black"
                                >DevOps / CI/CD:</strong
                            >
                            {cvData.skills.devops}
                        </li>
                        <li class="md:col-span-2">
                            <strong
                                class="text-slate-900 font-semibold print:text-black"
                                >{
                                    lang === "es"
                                        ? "Metodologías y Herramientas:"
                                        : "Methodologies & Tools:"
                                }</strong
                            >
                            {cvData.skills.agile}, {cvData.skills.platforms}
                        </li>
                    </ul>
                </section>

                <!-- Experience -->
                <section aria-labelledby="experience-heading">
                    <h2
                        id="experience-heading"
                        class="text-2xl font-bold text-slate-900 border-b-2 border-slate-100 pb-2 mb-6 print:text-xl print:border-slate-800/10 inline-block"
                    >
                        {t("cv.experience")}
                    </h2>
                    <div class="space-y-8 print:space-y-6">
                        {
                            cvData.experience.map((job) => (
                                <article class="relative pl-4 border-l-2 border-indigo-100 print:border-slate-300">
                                    <div class="absolute w-2.5 h-2.5 bg-indigo-600 rounded-full -left-[6px] top-1.5 ring-4 ring-white print:ring-0" />
                                    <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between mb-2">
                                        <h3 class="text-lg font-bold text-slate-900 print:text-black">
                                            {job.role}
                                        </h3>
                                        <span class="text-sm font-medium text-indigo-600 bg-indigo-50 px-2 py-0.5 rounded-full print:bg-transparent print:p-0 print:text-slate-600">
                                            {job.period}
                                        </span>
                                    </div>
                                    <div class="text-md font-medium text-slate-700 mb-3 print:mb-1">
                                        {job.company}{" "}
                                        <span class="text-slate-400 font-normal ml-1">
                                            | {job.location}
                                        </span>
                                    </div>
                                    <ul class="list-disc list-outside ml-4 space-y-1.5 text-slate-600 text-sm mb-3 print:text-slate-800">
                                        {job.achievements.map((item) => (
                                            <li>{item}</li>
                                        ))}
                                    </ul>
                                    <div class="text-sm text-slate-500 bg-slate-50 inline-block px-3 py-1 rounded-lg print:bg-transparent print:p-0 print:italic">
                                        <strong class="font-medium text-slate-700">
                                            {t("cv.tech")}
                                        </strong>{" "}
                                        {job.skills}
                                    </div>
                                </article>
                            ))
                        }
                    </div>
                </section>

                <div
                    class="grid grid-cols-1 md:grid-cols-2 gap-10 print:block print:space-y-6"
                >
                    <!-- Certifications -->
                    <section aria-labelledby="certifications-heading">
                        <h2
                            id="certifications-heading"
                            class="text-2xl font-bold text-slate-900 border-b-2 border-slate-100 pb-2 mb-4 print:text-xl print:border-slate-800/10 inline-block"
                        >
                            {t("cv.certifications")}
                        </h2>
                        <ul
                            class="list-disc list-outside ml-4 space-y-2 text-slate-600 text-sm print:text-slate-800"
                        >
                            {
                                cvData.certifications.map((cert) => (
                                    <li>{cert}</li>
                                ))
                            }
                        </ul>
                    </section>

                    <div>
                        <!-- Education -->
                        <section
                            aria-labelledby="education-heading"
                            class="mb-10 print:mb-6"
                        >
                            <h2
                                id="education-heading"
                                class="text-2xl font-bold text-slate-900 border-b-2 border-slate-100 pb-2 mb-4 print:text-xl print:border-slate-800/10 inline-block"
                            >
                                {t("cv.education")}
                            </h2>
                            <div class="space-y-4">
                                {
                                    cvData.education.map((edu) => (
                                        <div>
                                            <h3 class="text-md font-bold text-slate-900 print:text-black">
                                                {edu.degree}
                                            </h3>
                                            <div class="text-sm text-slate-600 mt-1 print:text-slate-800">
                                                {edu.institution}
                                            </div>
                                            <div class="text-sm text-slate-400 mt-0.5 print:text-slate-600">
                                                {edu.period}
                                            </div>
                                        </div>
                                    ))
                                }
                            </div>
                        </section>

                        <!-- Languages -->
                        <section aria-labelledby="languages-heading">
                            <h2
                                id="languages-heading"
                                class="text-2xl font-bold text-slate-900 border-b-2 border-slate-100 pb-2 mb-4 print:text-xl print:border-slate-800/10 inline-block"
                            >
                                {t("cv.languages")}
                            </h2>
                            <ul
                                class="space-y-2 text-sm text-slate-600 print:text-slate-800"
                            >
                                <li
                                    class="flex justify-between border-b border-slate-100 pb-1 print:border-dashed"
                                >
                                    <span
                                        class="font-medium text-slate-900 print:text-black"
                                        >{cvLanguagesLabels.es}</span
                                    >
                                    <span>{cvData.languages.es}</span>
                                </li>
                                <li
                                    class="flex justify-between border-b border-slate-100 pb-1 print:border-dashed"
                                >
                                    <span
                                        class="font-medium text-slate-900 print:text-black"
                                        >{cvLanguagesLabels.en}</span
                                    >
                                    <span>{cvData.languages.en}</span>
                                </li>
                            </ul>
                        </section>
                    </div>
                </div>
            </div>
        </main>
    </div>
</Layout>
